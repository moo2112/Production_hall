<%- include('partials/header') %>

<div class="row">
  <div class="col-12">
    <div class="text-center mb-4">
      <h2 class="fw-bold"><i class="bi bi-circle-fill text-success"></i> Primary Products</h2>
      <p class="text-muted">Base-level products used as components in secondary products</p>
    </div>

    <% if (error) { %>
      <div class="alert alert-danger alert-dismissible fade show"><i class="bi bi-exclamation-triangle"></i> <%= error %><button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    <% } %>
    <% if (success) { %>
      <div class="alert alert-success alert-dismissible fade show"><i class="bi bi-check-circle"></i> <%= success %><button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    <% } %>

    <div class="mb-3 d-flex gap-2 align-items-center flex-wrap">
      <button class="btn btn-success" data-bs-toggle="modal" data-bs-target="#encodeProductModal">
        <i class="bi bi-plus-circle"></i> Encode New Product
      </button>
      <small class="text-muted">
        <i class="bi bi-info-circle"></i>
        <em>Encoding only saves the product definition. Use <strong>Add Credit</strong> on each row to record actual production and increase stock.</em>
      </small>
    </div>

    <div class="card shadow-sm">
      <div class="card-body">
        <% if (products.length === 0) { %>
          <div class="text-center text-muted py-5">
            <i class="bi bi-inbox display-1 opacity-25"></i>
            <p class="mt-3">No primary products yet. Click <strong>Encode New Product</strong> to define one.</p>
          </div>
        <% } else { %>
          <div class="table-responsive">
            <table class="table table-hover align-middle">
              <thead class="table-light">
                <tr>
                  <th>#</th>
                  <th>Product Name</th>
                  <th>Stock</th>
                  <th>Description</th>
                  <th>Encoded On</th>
                  <th class="text-end">Actions</th>
                </tr>
              </thead>
              <tbody>
                <% products.forEach((product, index) => { %>
                  <tr>
                    <td><%= index + 1 %></td>
                    <td><strong><%= product.name %></strong></td>
                    <td>
                      <span class="badge bg-success fs-6">
                        <i class="bi bi-box-seam"></i> <%= product.quantity || 0 %> units
                      </span>
                      <% if (product.damagedQuantity && product.damagedQuantity > 0) { %>
                        <span class="badge bg-danger fs-6 ms-1" title="Total damaged">
                          <i class="bi bi-exclamation-triangle-fill"></i> <%= product.damagedQuantity %> dmg
                        </span>
                      <% } %>
                    </td>
                    <td class="text-muted small"><%= product.description || '-' %></td>
                    <td class="text-muted small">
                      <%= new Date(product.createdAt && product.createdAt.seconds ? product.createdAt.seconds * 1000 : product.createdAt).toLocaleDateString() %>
                    </td>
                    <td class="text-end">
                      <button class="btn btn-sm btn-success credit-btn"
                        data-id="<%= product.id %>"
                        data-name="<%= product.name %>">
                        <i class="bi bi-plus-circle-fill"></i> Add Credit
                      </button>
                      <button class="btn btn-sm btn-outline-warning ms-1" onclick="editProduct('<%= product.id %>')" title="Edit">
                        <i class="bi bi-pencil"></i>
                      </button>
                      <form action="/primary/<%= product.id %>?_method=DELETE" method="POST" style="display:inline">
                        <button type="submit" class="btn btn-sm btn-outline-danger ms-1"
                          onclick="return confirm('Delete this product? Cannot delete if used in secondary products.')">
                          <i class="bi bi-trash"></i>
                        </button>
                      </form>
                    </td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>
    </div>

    <div class="text-center mt-4">
      <a href="/secondary" class="btn btn-lg btn-outline-primary">
        Go to Secondary Products <i class="bi bi-arrow-right-circle ms-2"></i>
      </a>
    </div>
  </div>
</div>

<!-- ══════════════════════════════════════════════════════════════════════════ -->
<!-- MODAL 1 — ENCODE (name + description only)                                -->
<!-- ══════════════════════════════════════════════════════════════════════════ -->
<div class="modal fade" id="encodeProductModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header bg-success text-white">
        <h5 class="modal-title"><i class="bi bi-plus-circle"></i> Encode New Primary Product</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <form action="/primary" method="POST">
        <div class="modal-body">
          <div class="alert alert-info py-2 mb-3">
            <i class="bi bi-info-circle me-1"></i>
            <strong>Encoding only</strong> — saves the product name and description. Stock starts at zero. Use <em>Add Credit</em> to increase stock.
          </div>
          <div class="mb-3">
            <label class="form-label fw-semibold">Product Name <span class="text-danger">*</span></label>
            <input type="text" class="form-control" name="name" required placeholder="e.g. Tablet Base">
          </div>
          <div class="mb-3">
            <label class="form-label fw-semibold">Description</label>
            <input type="text" class="form-control" name="description" placeholder="Optional description">
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-success"><i class="bi bi-save"></i> Encode Product</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- ══════════════════════════════════════════════════════════════════════════ -->
<!-- MODAL 2 — ADD CREDIT (increases qty, no batch needed)                     -->
<!-- ══════════════════════════════════════════════════════════════════════════ -->
<div class="modal fade" id="creditModal" tabindex="-1">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
      <div class="modal-header bg-primary text-white">
        <h5 class="modal-title"><i class="bi bi-plus-circle-fill"></i> Add Production Credit — <span id="creditProductName"></span></h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <form id="creditForm" method="POST">
        <div class="modal-body">
          <div class="alert alert-primary py-2 mb-3">
            <i class="bi bi-info-circle me-1"></i>
            <strong>Production Credit</strong> — records produced quantity and increases stock.
          </div>

          <!-- Qty + Status -->
          <div class="card border-secondary">
            <div class="card-header bg-secondary text-white py-2">
              <small><i class="bi bi-123 me-1"></i> Step 2 — Quantity & Status</small>
            </div>
            <div class="card-body">
              <div class="row g-3">
                <div class="col-md-5">
                  <label class="form-label fw-semibold">Quantity Produced <span class="text-danger">*</span></label>
                  <input type="number" class="form-control" name="amount" id="creditAmount" step="0.01" min="0.01" required placeholder="e.g. 100">
                </div>
                <div class="col-md-7">
                  <label class="form-label fw-semibold">Production Status <span class="text-danger">*</span></label>
                  <div class="d-flex gap-3">
                    <div class="form-check flex-fill">
                      <input class="form-check-input" type="radio" name="productionStatus" id="p_statusFinished" value="Finished" required>
                      <label class="form-check-label w-100 p-2 border rounded text-center" for="p_statusFinished" style="cursor:pointer">
                        <i class="bi bi-check-circle-fill text-success fs-5 d-block mb-1"></i>
                        <strong>Finished</strong><br><small class="text-muted">Complete production</small>
                      </label>
                    </div>
                    <div class="form-check flex-fill">
                      <input class="form-check-input" type="radio" name="productionStatus" id="p_statusDamaged" value="Damaged">
                      <label class="form-check-label w-100 p-2 border rounded text-center" for="p_statusDamaged" style="cursor:pointer">
                        <i class="bi bi-exclamation-triangle-fill text-danger fs-5 d-block mb-1"></i>
                        <strong>Damaged</strong><br><small class="text-muted">Partial/damaged units</small>
                      </label>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-primary"><i class="bi bi-plus-circle-fill"></i> Add Production Credit</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- ══════════════════════════════════════════════════════════════════════════ -->
<!-- MODAL 3 — EDIT                                                             -->
<!-- ══════════════════════════════════════════════════════════════════════════ -->
<div class="modal fade" id="editProductModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header bg-warning text-dark">
        <h5 class="modal-title"><i class="bi bi-pencil"></i> Edit Primary Product</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <form id="editProductForm" method="POST">
        <input type="hidden" name="_method" value="PUT">
        <div class="modal-body">
          <div class="mb-3">
            <label class="form-label fw-semibold">Product Name <span class="text-danger">*</span></label>
            <input type="text" class="form-control" id="edit_name" name="name" required>
          </div>
          <div class="row g-3 mb-3">
            <div class="col-md-6">
              <label class="form-label fw-semibold">Stock (units)</label>
              <input type="number" class="form-control" id="edit_quantity" name="quantity" step="0.01" min="0" placeholder="0">
            </div>
            <div class="col-md-6">
              <label class="form-label fw-semibold text-danger"><i class="bi bi-exclamation-triangle-fill me-1"></i>Damages to Subtract</label>
              <input type="number" class="form-control border-danger" id="edit_damages" name="damages" step="0.01" min="0" value="0" placeholder="0">
              <small class="text-muted">Subtracted from stock on save.</small>
            </div>
          </div>
          <div class="mb-3">
            <label class="form-label fw-semibold">Description</label>
            <textarea class="form-control" id="edit_description" name="description" rows="2"></textarea>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-warning"><i class="bi bi-save"></i> Update</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
// ── Credit modal ──────────────────────────────────────────────────────────────
document.querySelectorAll('.credit-btn').forEach(function(btn) {
  btn.addEventListener('click', function() {
    const productId   = this.dataset.id;
    const productName = this.dataset.name;

    document.getElementById('creditProductName').textContent = productName;
    document.getElementById('creditForm').action = '/primary/' + productId + '/produce';
    document.querySelectorAll('input[name="productionStatus"]').forEach(function(r) { r.checked = false; });

    const amtInput = document.getElementById('creditAmount');
    if (amtInput) amtInput.value = '';

    new bootstrap.Modal(document.getElementById('creditModal')).show();
  });
});


document.getElementById('creditForm').addEventListener('submit', function(e) {
  const status = document.querySelector('input[name="productionStatus"]:checked');
  if (!status) {
    e.preventDefault();
    alert('Please select a production status (Finished or Damaged).');
    return;
  }

});

// ── Edit modal handled by main.js ─────────────────────────────────────────────
</script>

<%- include('partials/footer') %>
