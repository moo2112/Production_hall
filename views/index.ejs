<%- include('partials/header') %>

<div class="row justify-content-center">
  <div class="col-md-11">
    <div class="text-center mb-5">
      <h1 class="display-3 fw-bold text-primary">
        <i class="bi bi-building"></i> Production Hall
      </h1>
      <p class="lead text-muted">Multi-level Production Item Management System</p>
      <hr class="my-4">
    </div>

    <!-- Row 1 -->
    <div class="row g-4 mt-2">
      <div class="col-md-4">
        <a href="/consumables" class="text-decoration-none">
          <div class="card shadow-lg border-0 hover-card h-100">
            <div class="card-body text-center p-4">
              <i class="bi bi-box-seam display-3 text-info"></i>
              <h4 class="card-title fw-bold mt-3 mb-2">Consumables</h4>
              <p class="card-text text-muted small">Manage raw materials and supplies</p>
              <span class="btn btn-info btn-sm mt-2">Enter <i class="bi bi-arrow-right-circle ms-1"></i></span>
            </div>
          </div>
        </a>
      </div>
      <div class="col-md-4">
        <a href="/primary" class="text-decoration-none">
          <div class="card shadow-lg border-0 hover-card h-100">
            <div class="card-body text-center p-4">
              <i class="bi bi-circle-fill display-3 text-success"></i>
              <h4 class="card-title fw-bold mt-3 mb-2">Primary Products</h4>
              <p class="card-text text-muted small">First-level production items from consumables</p>
              <span class="btn btn-success btn-sm mt-2">Enter <i class="bi bi-arrow-right-circle ms-1"></i></span>
            </div>
          </div>
        </a>
      </div>
      <div class="col-md-4">
        <a href="/secondary" class="text-decoration-none">
          <div class="card shadow-lg border-0 hover-card h-100">
            <div class="card-body text-center p-4">
              <i class="bi bi-layer-forward display-3 text-warning"></i>
              <h4 class="card-title fw-bold mt-3 mb-2">Secondary Products</h4>
              <p class="card-text text-muted small">Assembled from primary product components</p>
              <span class="btn btn-warning btn-sm mt-2">Enter <i class="bi bi-arrow-right-circle ms-1"></i></span>
            </div>
          </div>
        </a>
      </div>
    </div>

    <!-- Row 2 -->
    <div class="row g-4 mt-2">
      <div class="col-md-4">
        <a href="/tertiary" class="text-decoration-none">
          <div class="card shadow-lg border-0 hover-card h-100">
            <div class="card-body text-center p-4">
              <i class="bi bi-diagram-3-fill display-3 text-danger"></i>
              <h4 class="card-title fw-bold mt-3 mb-2">Tertiary Products</h4>
              <p class="card-text text-muted small">Final-level products from secondary components</p>
              <span class="btn btn-danger btn-sm mt-2">Enter <i class="bi bi-arrow-right-circle ms-1"></i></span>
            </div>
          </div>
        </a>
      </div>
      <div class="col-md-4">
        <a href="/batch" class="text-decoration-none">
          <div class="card shadow-lg border-0 hover-card h-100">
            <div class="card-body text-center p-4">
              <i class="bi bi-collection display-3" style="color:#7c3aed"></i>
              <h4 class="card-title fw-bold mt-3 mb-2">Batch Management</h4>
              <p class="card-text text-muted small">Record and trace production batches</p>
              <span class="btn btn-sm mt-2" style="background:#7c3aed;color:#fff">Enter <i class="bi bi-arrow-right-circle ms-1"></i></span>
            </div>
          </div>
        </a>
      </div>
      <div class="col-md-4">
        <a href="/form-builder" class="text-decoration-none">
          <div class="card shadow-lg border-0 hover-card h-100">
            <div class="card-body text-center p-4">
              <i class="bi bi-ui-checks display-3 text-secondary"></i>
              <h4 class="card-title fw-bold mt-3 mb-2">Form Builder</h4>
              <p class="card-text text-muted small">Design custom batch entry forms</p>
              <span class="btn btn-secondary btn-sm mt-2">Enter <i class="bi bi-arrow-right-circle ms-1"></i></span>
            </div>
          </div>
        </a>
      </div>
    </div>

    <!-- Timeline Banner -->
    <div class="mt-4">
      <a href="/timeline" class="text-decoration-none">
        <div class="card border-0 shadow-sm hover-card" style="background:linear-gradient(135deg,#1e3a5f,#2d6a9f)">
          <div class="card-body d-flex align-items-center justify-content-between p-4">
            <div class="text-white">
              <h4 class="fw-bold mb-1"><i class="bi bi-clock-history me-2"></i>Activity Timeline</h4>
              <p class="mb-0 opacity-75">View the complete history of all system actions — export to PDF</p>
            </div>
            <span class="btn btn-light btn-lg">Open <i class="bi bi-arrow-right-circle ms-2"></i></span>
          </div>
        </div>
      </a>
    </div>

  </div>
</div>

<%- include('partials/footer') %>
