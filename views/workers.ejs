<%- include('partials/header') %>
<div class="row">
  <div class="col-12">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
      <h2 class="fw-bold"><i class="bi bi-shield-check text-success"></i> Production Room Quality</h2>
      <div class="d-flex gap-2 flex-wrap">
        <a href="/workers/quality" class="btn btn-success"><i class="bi bi-clipboard-check"></i> Record Round</a>
        <a href="/workers/errors" class="btn btn-warning"><i class="bi bi-exclamation-octagon"></i> Record Error</a>
        <button class="btn btn-info text-white" data-bs-toggle="modal" data-bs-target="#unifyModal"><i class="bi bi-magic"></i> Unify names with AI</button>
        <a href="/workers/pdf/all" class="btn btn-outline-danger"><i class="bi bi-file-earmark-pdf"></i> All PDFs</a>
        <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addWorkerModal"><i class="bi bi-person-plus"></i> New Worker</button>
      </div>
    </div>

    <% if (error) { %><div class="alert alert-danger"><i class="bi bi-exclamation-triangle"></i> <%= error %></div><% } %>
    <% if (success) { %><div class="alert alert-success"><i class="bi bi-check-circle"></i> <%= success %></div><% } %>

    <% if (!workers || workers.length === 0) { %>
      <div class="text-center text-muted py-5">
        <i class="bi bi-people" style="font-size:3rem"></i>
        <p class="mt-2">No workers yet. Add your first worker to start tracking precautions.</p>
      </div>
    <% } else { %>
      <div class="row g-3">
        <% workers.forEach(function(w){
             var rounds=(w.qualityRounds||[]); var errs=(w.productionErrors||[]);
             var noPrec=rounds.filter(function(r){return r.precautions!=='yes'}).length; %>
          <div class="col-md-6 col-lg-4">
            <div class="card h-100 shadow-sm">
              <div class="card-body">
                <div class="d-flex align-items-center mb-2">
                  <div class="rounded-circle bg-success text-white d-flex align-items-center justify-content-center me-2" style="width:42px;height:42px;font-weight:700">
                    <%= (w.name||'?').trim().charAt(0).toUpperCase() %>
                  </div>
                  <div>
                    <a href="/workers/<%= w.id %>" class="fw-bold text-decoration-none text-dark"><%= w.name %></a>
                    <div class="text-muted small"><%= w.role || 'Worker' %></div>
                  </div>
                </div>
                <div class="d-flex gap-2 flex-wrap mb-2">
                  <span class="badge bg-light text-dark border"><i class="bi bi-clipboard-check"></i> <%= rounds.length %> rounds</span>
                  <% if (noPrec) { %><span class="badge bg-danger-subtle text-danger border"><i class="bi bi-x-octagon"></i> <%= noPrec %> no-precaution</span><% } %>
                  <% if (errs.length) { %><span class="badge bg-warning-subtle text-warning-emphasis border"><i class="bi bi-exclamation-triangle"></i> <%= errs.length %> errors</span><% } %>
                </div>
                <div class="d-flex gap-2">
                  <a href="/workers/<%= w.id %>" class="btn btn-sm btn-outline-primary">Profile</a>
                  <a href="/workers/<%= w.id %>/pdf" class="btn btn-sm btn-outline-danger"><i class="bi bi-file-earmark-pdf"></i> PDF</a>
                </div>
              </div>
            </div>
          </div>
        <% }); %>
      </div>
    <% } %>
  </div>
</div>

<!-- Add Worker modal -->
<div class="modal fade" id="addWorkerModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <form method="POST" action="/workers">
        <div class="modal-header"><h5 class="modal-title"><i class="bi bi-person-plus"></i> New Worker</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
        <div class="modal-body">
          <div class="mb-3"><label class="form-label fw-semibold">Name <span class="text-danger">*</span></label>
            <input type="text" name="name" class="form-control" required placeholder="e.g. Ahmed Mahmoud"></div>
          <div class="mb-3"><label class="form-label fw-semibold">Role / Station</label>
            <input type="text" name="role" class="form-control" placeholder="e.g. Bottle filling line"></div>
        </div>
        <div class="modal-footer"><button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-primary">Add Worker</button></div>
      </form>
    </div>
  </div>
</div>
<!-- Unify names with AI modal -->
<div class="modal fade" id="unifyModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <form method="POST" action="/workers/unify" onsubmit="return confirm('This will merge profiles whose names look like the same person (e.g. Ibrahim / ebrahim) into ONE profile and delete the extras. Their batches, rounds and errors are kept on the surviving profile. Continue?');">
        <div class="modal-header">
          <h5 class="modal-title"><i class="bi bi-magic text-info"></i> Unify worker names with AI</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <p class="text-muted small">
            The old data has the same person written several ways (Arabic/English, spelling variants). This uses OpenAI to detect those and keep <strong>one profile per worker</strong>, moving all their batches/rounds/errors onto it and deleting duplicates. Different people are never merged.
          </p>
          <div class="mb-3">
            <label class="form-label fw-semibold">OpenAI API key <span class="text-danger">*</span></label>
            <input type="password" name="apiKey" class="form-control" required placeholder="sk-..." autocomplete="off">
            <div class="form-text">Used only for this request and not saved anywhere.</div>
          </div>
          <div class="mb-3">
            <label class="form-label fw-semibold">Model</label>
            <select name="model" class="form-select">
              <option value="gpt-4.1-mini" selected>gpt-4.1-mini — recommended (cheap, multilingual)</option>
              <option value="gpt-4.1">gpt-4.1 — higher accuracy</option>
              <option value="gpt-5.4">gpt-5.4 — best quality</option>
              <option value="gpt-4.1-nano">gpt-4.1-nano — cheapest</option>
              <option value="gpt-4o-mini">gpt-4o-mini — legacy</option>
            </select>
          </div>
          <div class="alert alert-warning small mb-0">
            <i class="bi bi-exclamation-triangle"></i> This permanently deletes duplicate profiles. Consider downloading <a href="/workers/pdf/all" target="_blank">All PDFs</a> first as a backup.
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-info text-white"><i class="bi bi-magic"></i> Start unifying</button>
        </div>
      </form>
    </div>
  </div>
</div>
<%- include('partials/footer') %>
