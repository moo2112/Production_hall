<%- include('partials/header') %>

<div class="row">
  <div class="col-12">
    <div class="text-center mb-4">
      <h2 class="fw-bold"><i class="bi bi-collection" style="color:#7c3aed"></i> Batch Management</h2>
      <p class="text-muted">Record and trace production batches across all product tiers</p>
    </div>

    <% if (error) { %>
      <div class="alert alert-danger alert-dismissible fade show">
        <i class="bi bi-exclamation-triangle"></i> <%= error %>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      </div>
    <% } %>
    <% if (success) { %>
      <div class="alert alert-success alert-dismissible fade show">
        <i class="bi bi-check-circle"></i> <%= success %>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      </div>
    <% } %>

    <div class="mb-3 d-flex gap-2">
      <button class="btn" style="background:#7c3aed;color:#fff"
              data-bs-toggle="modal" data-bs-target="#addBatchModal">
        <i class="bi bi-plus-circle"></i> New Batch Record
      </button>
      <a href="/form-builder" class="btn btn-outline-secondary">
        <i class="bi bi-ui-checks"></i> Manage Form Templates
      </a>
    </div>

    <!-- Batch Records Table -->
    <div class="card shadow-sm">
      <div class="card-body">
        <% if (batches.length === 0) { %>
          <div class="text-center text-muted py-5">
            <i class="bi bi-collection display-1" style="opacity:.2;color:#7c3aed"></i>
            <p class="mt-3">No batches recorded yet. Click "New Batch Record" to get started.</p>
          </div>
        <% } else { %>
          <!-- Search across all batches -->
          <div class="row mb-3">
            <div class="col-md-6 col-lg-5">
              <div class="input-group">
                <span class="input-group-text" style="background:#7c3aed;color:#fff"><i class="bi bi-search"></i></span>
                <input type="text" id="batchSearch" class="form-control" placeholder="Search batches — number, item, type, status, date…" autocomplete="off">
                <button class="btn btn-outline-secondary" type="button" id="batchSearchClear" title="Clear"><i class="bi bi-x-lg"></i></button>
              </div>
            </div>
            <div class="col-md-6 col-lg-7 d-flex align-items-center">
              <small class="text-muted ms-md-2" id="batchSearchCount"></small>
            </div>
          </div>
          <div class="table-responsive">
            <table class="table table-hover align-middle" id="batchTable">
              <thead class="table-light">
                <tr>
                  <th>#</th>
                  <th>Batch Number</th>
                  <th>Item Name</th>
                  <th>Item Type</th>
                  <th>Form Template</th>
                  <th>QC Status</th>
                  <th>Date Recorded</th>
                  <th class="text-end">Actions</th>
                </tr>
              </thead>
              <tbody id="batchTableBody">
                <% batches.forEach(function(batch, index) {
                  var qs = batch.qualityStatus || null;
                  var hasReport = (qs === 'rejected') && batch.rejectionReport;
                  var rowBg = qs === 'rejected' ? 'background:#fef2f2;'
                            : qs === 'accepted' ? 'background:#f0fdf4;'
                            : '';
                  var typeColors = {Primary:'success', Secondary:'warning', Tertiary:'danger'};
                  var typeColor  = typeColors[batch.itemType] || 'secondary';
                %>
                  <tr style="<%= rowBg %>">
                    <td><%= index + 1 %></td>

                    <!-- Batch number -->
                    <td>
                      <button type="button"
                              class="btn btn-sm text-white fw-semibold view-batch-btn"
                              style="background:#7c3aed"
                              data-batch-id="<%= batch.id %>"
                              title="View all products related to this batch">
                        <i class="bi bi-tag-fill me-1"></i><%= batch.batchNumber %>
                      </button>
                      <% if (qs === 'rejected') { %>
                        <span class="badge ms-1"
                              style="background:#dc2626;color:#fff;font-size:.65rem;">
                          <i class="bi bi-shield-x"></i> REJECTED
                        </span>
                      <% } else if (qs === 'accepted') { %>
                        <span class="badge ms-1"
                              style="background:#16a34a;color:#fff;font-size:.65rem;">
                          <i class="bi bi-shield-check"></i> ACCEPTED
                        </span>
                      <% } %>
                    </td>

                    <td><strong><%= batch.itemName %></strong></td>

                    <td>
                      <span class="badge bg-<%= typeColor %>"><%= batch.itemType || '-' %></span>
                    </td>

                    <td>
                      <% if (batch.formTemplateName) { %>
                        <%= batch.formTemplateName %>
                      <% } else { %>
                        <span class="text-muted">-</span>
                      <% } %>
                    </td>

                    <!-- QC Status column -->
                    <td>
                      <% if (qs === 'accepted') { %>
                        <span class="badge bg-success">
                          <i class="bi bi-check-circle me-1"></i>Accepted
                        </span>
                      <% } else if (qs === 'rejected') { %>
                        <span class="badge bg-danger">
                          <i class="bi bi-x-circle me-1"></i>Rejected
                        </span>
                        <% if (hasReport) { %>
                          <div class="mt-1">
                            <%
                              /*
                               * Use data attributes only — no JS escaping inside EJS.
                               * The click handler reads these attributes safely.
                               */
                            %>
                            <button type="button"
                                    class="btn btn-link btn-sm p-0 text-danger view-report-btn"
                                    style="font-size:.78rem;"
                                    data-batch-id="<%= batch.id %>"
                                    data-batch-number="<%= batch.batchNumber %>">
                              <i class="bi bi-file-text me-1"></i>View Report
                            </button>
                          </div>
                        <% } %>
                      <% } else if (qs === 'pending') { %>
                        <span class="badge bg-warning text-dark">
                          <i class="bi bi-hourglass-split me-1"></i>Pending
                        </span>
                      <% } else { %>
                        <span class="badge bg-light text-muted border">Not reviewed</span>
                      <% } %>
                    </td>

                    <td class="text-muted small">
                      <%
                        var batchDate = batch.createdAt;
                        var dateStr = '—';
                        if (batchDate) {
                          var d = batchDate.toDate ? batchDate.toDate() : new Date(batchDate);
                          if (!isNaN(d.getTime())) dateStr = d.toLocaleString();
                        }
                      %>
                      <%= dateStr %>
                    </td>

                    <td class="text-end">
                      <button class="btn btn-sm btn-outline-info view-batch-btn"
                              data-batch-id="<%= batch.id %>"
                              title="View Details">
                        <i class="bi bi-eye"></i>
                      </button>
                      <form action="/batch/<%= batch.id %>?_method=DELETE" method="POST"
                            style="display:inline">
                        <button type="submit" class="btn btn-sm btn-outline-danger"
                                onclick="return confirm('Delete this batch record?')">
                          <i class="bi bi-trash"></i>
                        </button>
                      </form>
                    </td>
                  </tr>
                <% }); %>
                <tr id="batchNoResults" style="display:none"><td colspan="8" class="text-center text-muted py-4"><i class="bi bi-search"></i> No batches match your search.</td></tr>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</div>

<!-- ── Add Batch Modal ──────────────────────────────────────────────────────── -->
<div class="modal fade" id="addBatchModal" tabindex="-1">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
      <div class="modal-header text-white" style="background:#7c3aed">
        <h5 class="modal-title"><i class="bi bi-plus-circle"></i> New Batch Record</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <form id="batchForm" action="/batch" method="POST">
        <div class="modal-body">

          <div class="mb-4">
            <label class="form-label fw-semibold">
              Form Template <span class="text-muted fw-normal">(optional)</span>
            </label>
            <select class="form-select" id="templateSelector" onchange="loadTemplate(this.value)">
              <option value="">— No template / use default fields —</option>
              <% templates.forEach(function(t) { %>
                <option value="<%= t.id %>"
                        data-name="<%= t.name %>"
                        data-fields="<%- encodeURIComponent(JSON.stringify(t.fields || [])) %>">
                  <%= t.name %>
                </option>
              <% }); %>
            </select>
            <input type="hidden" name="formTemplateId"   id="formTemplateId">
            <input type="hidden" name="formTemplateName" id="formTemplateName">
          </div>

          <div class="card border-primary mb-3">
            <div class="card-header bg-primary text-white py-2">
              <small><i class="bi bi-lock-fill me-1"></i> Required Fields — always present</small>
            </div>
            <div class="card-body">
              <div class="row g-3">
                <div class="col-md-6">
                  <label class="form-label fw-semibold">
                    Batch Number <span class="text-danger">*</span>
                  </label>
                  <input type="text" class="form-control" name="batchNumber" id="batchNumberInput"
                         placeholder="e.g. BATCH-2024-001" autocomplete="off" required>
                  <div id="batchNumberFeedback" class="form-text"></div>
                </div>
                <div class="col-md-6">
                  <label class="form-label fw-semibold">
                    Item Name <span class="text-danger">*</span>
                  </label>
                  <select class="form-select" name="itemId" id="itemSelector"
                          required onchange="syncItemName(this)">
                    <option value="">— Select a product —</option>
                    <%
                      var grouped = {Primary:[], Secondary:[], Tertiary:[]};
                      allProducts.forEach(function(p) {
                        if (grouped[p.productType]) grouped[p.productType].push(p);
                      });
                      ['Primary','Secondary','Tertiary'].forEach(function(type) {
                        if (grouped[type].length > 0) {
                    %>
                      <optgroup label="<%= type %> Products">
                        <% grouped[type].forEach(function(p) { %>
                          <option value="<%= p.id %>"
                                  data-type="<%= type %>"
                                  data-name="<%= p.name %>">
                            <%= p.name %>
                          </option>
                        <% }); %>
                      </optgroup>
                    <%  }
                      });
                    %>
                  </select>
                  <input type="hidden" name="itemName" id="itemName">
                  <input type="hidden" name="itemType" id="itemType">
                </div>
              </div>
            </div>
          </div>

          <div id="dynamicFieldsContainer"></div>

        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn text-white" style="background:#7c3aed">
            <i class="bi bi-save"></i> Save Batch Record
          </button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- ── Batch Detail Modal ─────────────────────────────────────────────────────  -->
<div class="modal fade" id="batchDetailModal" tabindex="-1">
  <div class="modal-dialog modal-xl">
    <div class="modal-content">
      <div class="modal-header text-white" style="background:#7c3aed">
        <h5 class="modal-title">
          <i class="bi bi-diagram-3"></i> Batch Details &amp; Product Traceability
        </h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body" id="batchDetailBody">
        <div class="text-center text-muted py-4">Loading batch details…</div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
      </div>
    </div>
  </div>
</div>

<!-- ── QC Rejection Report Modal ─────────────────────────────────────────────  -->
<div class="modal fade" id="qcReportModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content border-0 shadow-lg">
      <div class="modal-header" style="background:#dc2626;color:#fff;">
        <h5 class="modal-title">
          <i class="bi bi-file-text me-2"></i>QC Rejection Report
          &mdash; <span id="qcReportBatchNumber"></span>
        </h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body" id="qcReportBody">
        <div class="text-center text-muted py-3">
          <div class="spinner-border spinner-border-sm me-2"></div>Loading…
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
      </div>
    </div>
  </div>
</div>

<script>
  window.__WORKERS__ = <%- JSON.stringify((typeof workers !== 'undefined' && workers) ? workers.map(function(w){return {id:w.id,name:w.name};}) : []) %>;
  /* ── Helpers ──────────────────────────────────────────────────────────────── */
  // Clone a worker dropdown so several workers can be recorded for one task.
  function addWorkerSelect(btn) {
    var wrap = btn.closest('.worker-multi-wrap');
    if (!wrap) return;
    var opts = wrap.querySelector('.worker-options');
    var first = opts.querySelector('select');
    if (!first) return;
    var row = document.createElement('div');
    row.className = 'd-flex gap-1 mb-1 align-items-center';
    var clone = first.cloneNode(true);
    clone.selectedIndex = 0;
    clone.removeAttribute('required'); // only the first one is required
    clone.classList.remove('mb-1');
    var rm = document.createElement('button');
    rm.type = 'button';
    rm.className = 'btn btn-sm btn-outline-danger';
    rm.innerHTML = '<i class="bi bi-x"></i>';
    rm.onclick = function () { row.remove(); };
    row.appendChild(clone);
    row.appendChild(rm);
    opts.appendChild(row);
  }
  function escapeHtml(value) {
    return String(value ?? '')
      .replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')
      .replace(/"/g,'&quot;').replace(/'/g,'&#039;');
  }
  function formatDate(value) {
    if (!value) return '-';
    if (value._seconds) return new Date(value._seconds * 1000).toLocaleString();
    if (value.seconds)  return new Date(value.seconds  * 1000).toLocaleString();
    var d = new Date(value);
    return isNaN(d.getTime()) ? '-' : d.toLocaleString();
  }
  function formatUnits(value) {
    var n = parseFloat(value || 0);
    return Number.isInteger(n) ? String(n) : n.toFixed(2).replace(/\.00$/, '');
  }
  function fieldInputName(fieldId) {
    var raw = String(fieldId || '').trim();
    return raw && !raw.startsWith('field_') ? 'field_' + raw : raw;
  }
  function humanizeFieldKey(key) {
    return String(key || '')
      .replace(/^field_/, '').replace(/[_-]+/g, ' ')
      .replace(/\b\w/g, function(c) { return c.toUpperCase(); })
      .trim() || 'Custom Field';
  }
  function displayFieldValue(value) {
    return value === null || value === undefined || String(value) === '' ? '-' : String(value);
  }
  function toDateInputValue(value) {
    if (!value) return '';
    var raw = String(value);
    if (/^\d{4}-\d{2}-\d{2}$/.test(raw)) return raw;
    var d = new Date(raw);
    return isNaN(d.getTime()) ? '' : d.toISOString().slice(0, 10);
  }

  var currentBatchDetails = null;

  /* ── Add-batch modal ──────────────────────────────────────────────────────── */
  function syncItemName(sel) {
    var opt = sel.options[sel.selectedIndex];
    document.getElementById('itemName').value = opt.dataset.name || '';
    document.getElementById('itemType').value = opt.dataset.type || '';
  }

  function loadTemplate(templateId) {
    var sel = document.getElementById('templateSelector');
    var opt = sel.options[sel.selectedIndex];
    document.getElementById('formTemplateId').value   = templateId || '';
    document.getElementById('formTemplateName').value = opt ? (opt.dataset.name || '') : '';

    var container = document.getElementById('dynamicFieldsContainer');
    container.innerHTML = '';
    if (!templateId || !opt) return;

    var fields = [];
    try { fields = JSON.parse(decodeURIComponent(opt.dataset.fields || '[]')); } catch(e) {}
    if (!fields.length) return;

    var html = '<div class="card border-secondary">'
             + '<div class="card-header bg-secondary text-white py-2">'
             + '<small><i class="bi bi-ui-checks me-1"></i> Template Fields</small>'
             + '</div><div class="card-body"><div class="row g-3">';

    fields.forEach(function(f) {
      var req       = f.required ? 'required' : '';
      var reqMark   = f.required ? '<span class="text-danger">*</span>' : '';
      var inputName = fieldInputName(f.id);
      html += '<div class="col-md-6"><label class="form-label fw-semibold">'
            + escapeHtml(f.label) + ' ' + reqMark + '</label>';

      if (f.type === 'notes') {
        html += '<input type="text" class="form-control" name="' + escapeHtml(inputName)
              + '" placeholder="' + escapeHtml(f.label) + '" ' + req + '>';
      } else if (f.type === 'number') {
        html += '<input type="number" class="form-control" name="' + escapeHtml(inputName)
              + '" step="0.01" ' + req + '>';
      } else if (f.type === 'date') {
        html += '<input type="date" class="form-control" name="' + escapeHtml(inputName)
              + '" ' + req + '>';
      } else if (f.type === 'dropdown' && f.options && f.options.length) {
        html += '<select class="form-select" name="' + escapeHtml(inputName) + '" ' + req
              + '><option value="">— Select —</option>';
        f.options.forEach(function(o) {
          html += '<option value="' + escapeHtml(o) + '">' + escapeHtml(o) + '</option>';
        });
        html += '</select>';
      } else if (f.type === 'text' || f.type === 'worker') {
        // Text answers are chosen from existing worker profiles (not free-typed).
        // Several workers can be recorded for the same task via "Add another worker".
        var workers = window.__WORKERS__ || [];
        if (workers.length) {
          var optionsHtml = '<option value="">— Select worker —</option>';
          workers.forEach(function(w) {
            optionsHtml += '<option value="' + escapeHtml(w.name) + '">' + escapeHtml(w.name) + '</option>';
          });
          html += '<div class="worker-multi-wrap">'
                + '<div class="worker-options">'
                + '<select class="form-select mb-1" name="' + escapeHtml(inputName) + '" ' + req + '>'
                + optionsHtml + '</select>'
                + '</div>'
                + '<button type="button" class="btn btn-sm btn-outline-secondary" onclick="addWorkerSelect(this)">'
                + '<i class="bi bi-person-plus"></i> Add another worker</button>'
                + '</div>';
        } else {
          // No worker profiles yet — fall back to a plain input so the form still works.
          html += '<input type="text" class="form-control" name="' + escapeHtml(inputName)
                + '" placeholder="No worker profiles yet — type a name" ' + req + '>';
        }
      } else {
        html += '<input type="text" class="form-control" name="' + escapeHtml(inputName)
              + '" ' + req + '>';
      }
      html += '</div>';
    });
    html += '</div></div></div>';
    container.innerHTML = html;
  }

  /* ── View batch detail — wired via event delegation ──────────────────────── */
  document.addEventListener('click', function(e) {
    var btn = e.target.closest('.view-batch-btn');
    if (!btn) return;
    viewBatchDetails(btn.dataset.batchId);
  });

  async function viewBatchDetails(batchId) {
    var body = document.getElementById('batchDetailBody');
    body.innerHTML = '<div class="text-center text-muted py-4">'
                   + '<div class="spinner-border spinner-border-sm me-2"></div>'
                   + 'Loading batch details…</div>';
    new bootstrap.Modal(document.getElementById('batchDetailModal')).show();
    try {
      var response = await fetch('/batch/api/' + batchId + '/details');
      var payload  = await response.json();
      if (!response.ok || payload.error) throw new Error(payload.error || 'Failed to load');
      currentBatchDetails = payload;
      renderBatchDetails(payload, false);
    } catch (err) {
      body.innerHTML = '<div class="alert alert-danger mb-0">'
                     + '<i class="bi bi-exclamation-triangle me-1"></i>'
                     + escapeHtml(err.message) + '</div>';
    }
  }

  function getFieldsToShow(payload) {
    var batch        = payload.batch        || {};
    var customFields = payload.customFields || [];
    var fieldValues  = batch.fieldValues    || {};

    return customFields.length > 0 ? customFields
      : Object.entries(fieldValues).map(function(e) {
          return {
            key: e[0],
            label: humanizeFieldKey(e[0]),
            value: e[1],
            type: 'text',
            required: false,
            options: []
          };
        });
  }

  function renderEditableFieldInput(field) {
    var key         = String(field.key || '').trim();
    var label       = field.label || humanizeFieldKey(key);
    var type        = field.type || 'text';
    var value       = field.value == null ? '' : String(field.value);
    var required    = field.required ? ' required' : '';
    var requiredTag = field.required ? ' <span class="text-danger">*</span>' : '';
    var html        = '<div class="col-md-6">'
                    + '<label class="form-label fw-semibold">'
                    + escapeHtml(label) + requiredTag + '</label>';

    if (type === 'number') {
      html += '<input type="number" step="0.01" class="form-control custom-field-input"'
            + ' data-field-key="' + escapeHtml(key) + '"'
            + ' value="' + escapeHtml(value) + '"' + required + '>';
    } else if (type === 'date') {
      html += '<input type="date" class="form-control custom-field-input"'
            + ' data-field-key="' + escapeHtml(key) + '"'
            + ' value="' + escapeHtml(toDateInputValue(value)) + '"' + required + '>';
    } else if (type === 'dropdown' && Array.isArray(field.options) && field.options.length > 0) {
      var options = field.options.slice();
      if (value && !options.includes(value)) options.unshift(value);
      html += '<select class="form-select custom-field-input"'
            + ' data-field-key="' + escapeHtml(key) + '"' + required + '>'
            + '<option value="">— Select —</option>';
      options.forEach(function(option) {
        var selected = String(option) === value ? ' selected' : '';
        html += '<option value="' + escapeHtml(option) + '"' + selected + '>'
              + escapeHtml(option) + '</option>';
      });
      html += '</select>';
    } else if (type === 'notes') {
      html += '<textarea class="form-control custom-field-input" rows="3"'
            + ' data-field-key="' + escapeHtml(key) + '"' + required + '>'
            + escapeHtml(value) + '</textarea>';
    } else if (type === 'worker') {
      var wopts = (window.__WORKERS__ || []).map(function(w){ return w.name; });
      if (value && wopts.indexOf(value) === -1) wopts.unshift(value);
      html += '<select class="form-select custom-field-input"'
            + ' data-field-key="' + escapeHtml(key) + '"' + required + '>'
            + '<option value="">— Select worker —</option>';
      wopts.forEach(function(option) {
        var selected = String(option) === value ? ' selected' : '';
        html += '<option value="' + escapeHtml(option) + '"' + selected + '>'
              + escapeHtml(option) + '</option>';
      });
      html += '</select>';
    } else {
      html += '<input type="text" class="form-control custom-field-input"'
            + ' data-field-key="' + escapeHtml(key) + '"'
            + ' value="' + escapeHtml(value) + '"' + required + '>';
    }

    html += '</div>';
    return html;
  }

  function showBatchDetailAlert(type, message) {
    var holder = document.getElementById('batchDetailAlert');
    if (!holder) return;
    holder.innerHTML = '<div class="alert alert-' + escapeHtml(type) + ' alert-dismissible fade show">'
                     + escapeHtml(message)
                     + '<button type="button" class="btn-close" data-bs-dismiss="alert"></button>'
                     + '</div>';
  }

  function renderBatchDetails(payload, editMode) {
    currentBatchDetails = payload;

    var batch          = payload.batch              || {};
    var directProducts = payload.directProducts     || [];
    var consumedBy     = payload.consumedByProducts || [];
    var fieldsToShow   = getFieldsToShow(payload);
    var qs             = batch.qualityStatus        || null;

    var html = '<div id="batchDetailAlert"></div>';

    /* QC status banner */
    if (qs === 'rejected') {
      html += '<div class="alert alert-danger d-flex gap-3 align-items-start mb-3">'
            + '<i class="bi bi-shield-x fs-4 flex-shrink-0"></i><div>'
            + '<strong>This batch has been REJECTED by Quality Control.</strong>'
            + '<div class="mt-1">'
            + '<button type="button" class="btn btn-link btn-sm p-0 text-danger view-report-btn-detail"'
            + ' data-batch-id="' + escapeHtml(batch.id) + '"'
            + ' data-batch-number="' + escapeHtml(batch.batchNumber) + '">'
            + '<i class="bi bi-file-text me-1"></i>View Rejection Report'
            + '</button></div></div></div>';
    } else if (qs === 'accepted') {
      html += '<div class="alert alert-success d-flex gap-3 align-items-center mb-3 py-2">'
            + '<i class="bi bi-shield-check fs-5"></i>'
            + '<strong>Accepted by Quality Control</strong></div>';
    }

    /* Summary row */
    html += '<div class="batch-detail-summary mb-4"><div class="row g-3">'
          + '<div class="col-md-3"><div class="trace-card"><span class="trace-label">Batch Number</span>'
          + '<strong>' + escapeHtml(batch.batchNumber || '-') + '</strong></div></div>'
          + '<div class="col-md-3"><div class="trace-card"><span class="trace-label">Linked Item</span>'
          + '<strong>' + escapeHtml(batch.itemName || '-') + '</strong></div></div>'
          + '<div class="col-md-3"><div class="trace-card"><span class="trace-label">Item Type</span>'
          + '<strong>' + escapeHtml(batch.itemType || '-') + '</strong></div></div>'
          + '<div class="col-md-3"><div class="trace-card"><span class="trace-label">Recorded</span>'
          + '<strong>' + escapeHtml(formatDate(batch.createdAt)) + '</strong></div></div>'
          + '</div></div>';

    /* Custom fields */
    if (fieldsToShow.length > 0) {
      html += '<div class="card border-0 shadow-sm mb-4">'
            + '<div class="card-header bg-light d-flex justify-content-between align-items-center gap-2">'
            + '<div class="fw-semibold"><i class="bi bi-ui-checks me-1"></i>Custom Fields';
      if (payload.templateName)
        html += ' <span class="badge bg-secondary ms-2">' + escapeHtml(payload.templateName) + '</span>';
      html += '</div>';

      if (!editMode) {
        html += '<button type="button" class="btn btn-sm btn-outline-primary edit-custom-fields-btn">'
              + '<i class="bi bi-pencil-square me-1"></i>Edit Custom Fields'
              + '</button>';
      }

      html += '</div><div class="card-body">';

      if (editMode) {
        html += '<form id="editCustomFieldsForm">'
              + '<div class="row g-3">';
        fieldsToShow.forEach(function(field) {
          html += renderEditableFieldInput(field);
        });
        html += '</div>'
              + '<div class="d-flex justify-content-end gap-2 mt-3">'
              + '<button type="button" class="btn btn-outline-secondary cancel-custom-fields-btn">Cancel</button>'
              + '<button type="submit" class="btn btn-primary save-custom-fields-btn">'
              + '<i class="bi bi-save me-1"></i>Save Changes'
              + '</button>'
              + '</div></form>';
      } else {
        html += '<div class="row g-2">';
        fieldsToShow.forEach(function(field) {
          html += '<div class="col-md-6">'
                + '<div class="small text-muted">'
                + escapeHtml(field.label || humanizeFieldKey(field.key))
                + '</div>'
                + '<div class="fw-semibold">'
                + escapeHtml(displayFieldValue(field.value))
                + '</div></div>';
        });
        html += '</div>';
      }

      html += '</div></div>';
    }

    /* Products tables */
    html += '<div class="row g-3">';

    /* Direct stock */
    html += '<div class="col-lg-6"><div class="card h-100 border-0 shadow-sm">'
          + '<div class="card-header bg-light fw-semibold">'
          + '<i class="bi bi-box-seam me-1"></i>Products with available stock in this batch'
          + '</div><div class="card-body">';
    if (!directProducts.length) {
      html += '<div class="text-muted text-center py-4">'
            + '<i class="bi bi-inbox display-6 opacity-25"></i>'
            + '<p class="mb-0 mt-2">No secondary or tertiary stock has been credited yet.</p>'
            + '</div>';
    } else {
      html += '<div class="table-responsive"><table class="table table-sm align-middle mb-0">'
            + '<thead><tr><th>Tier</th><th>Product</th><th>Units</th><th>Relationship</th></tr></thead><tbody>';
      directProducts.forEach(function(item) {
        var bc = item.tier === 'Tertiary' ? 'bg-danger' : 'bg-warning text-dark';
        html += '<tr><td><span class="badge ' + bc + '">' + escapeHtml(item.tier) + '</span></td>'
              + '<td class="fw-semibold">' + escapeHtml(item.productName) + '</td>'
              + '<td>' + formatUnits(item.units) + '</td>'
              + '<td class="small text-muted">' + escapeHtml(item.relationship) + '</td></tr>';
      });
      html += '</tbody></table></div>';
    }
    html += '</div></div></div>';

    /* Consumed by */
    html += '<div class="col-lg-6"><div class="card h-100 border-0 shadow-sm">'
          + '<div class="card-header bg-light fw-semibold">'
          + '<i class="bi bi-arrow-left-right me-1"></i>Products that consumed this batch'
          + '</div><div class="card-body">';
    if (!consumedBy.length) {
      html += '<div class="text-muted text-center py-4">'
            + '<i class="bi bi-diagram-3 display-6 opacity-25"></i>'
            + '<p class="mb-0 mt-2">No tertiary product has consumed this batch yet.</p>'
            + '</div>';
    } else {
      html += '<div class="table-responsive"><table class="table table-sm align-middle mb-0">'
            + '<thead><tr><th>Tertiary Product</th><th>Tertiary Batch</th>'
            + '<th>Secondary Input</th><th>Units Used</th></tr></thead><tbody>';
      consumedBy.forEach(function(item) {
        html += '<tr><td class="fw-semibold">' + escapeHtml(item.productName) + '</td>'
              + '<td><span class="badge bg-danger">' + escapeHtml(item.tertiaryBatchNumber || '-') + '</span></td>'
              + '<td>' + escapeHtml(item.sourceProductName || '-') + '</td>'
              + '<td>' + formatUnits(item.units) + '</td></tr>';
      });
      html += '</tbody></table></div>';
    }
    html += '</div></div></div></div>';

    document.getElementById('batchDetailBody').innerHTML = html;

    /* Wire the "View Rejection Report" button that was just injected into the DOM */
    document.querySelectorAll('.view-report-btn-detail').forEach(function(btn) {
      btn.addEventListener('click', function() {
        openQcReportModal(this.dataset.batchId, this.dataset.batchNumber);
      });
    });
  }

  /* ── Edit custom fields inside Batch Details ─────────────────────────────── */
  document.addEventListener('click', function(e) {
    var editBtn = e.target.closest('.edit-custom-fields-btn');
    if (editBtn && currentBatchDetails) {
      renderBatchDetails(currentBatchDetails, true);
      return;
    }

    var cancelBtn = e.target.closest('.cancel-custom-fields-btn');
    if (cancelBtn && currentBatchDetails) {
      renderBatchDetails(currentBatchDetails, false);
    }
  });

  document.addEventListener('submit', async function(e) {
    if (!e.target.matches('#editCustomFieldsForm')) return;
    e.preventDefault();

    if (!currentBatchDetails || !currentBatchDetails.batch || !currentBatchDetails.batch.id) return;

    var form       = e.target;
    var saveButton = form.querySelector('.save-custom-fields-btn');
    var fieldValues = {};

    form.querySelectorAll('.custom-field-input').forEach(function(input) {
      fieldValues[input.dataset.fieldKey] = input.value;
    });

    if (saveButton) {
      saveButton.disabled = true;
      saveButton.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Saving...';
    }

    try {
      var response = await fetch('/batch/api/' + currentBatchDetails.batch.id + '/custom-fields', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ fieldValues: fieldValues })
      });
      var payload = await response.json();
      if (!response.ok || payload.error) throw new Error(payload.error || 'Failed to update custom fields');

      currentBatchDetails = payload;
      renderBatchDetails(payload, false);
      showBatchDetailAlert('success', 'Custom field values updated successfully.');
    } catch (err) {
      showBatchDetailAlert('danger', err.message);
      if (saveButton) {
        saveButton.disabled = false;
        saveButton.innerHTML = '<i class="bi bi-save me-1"></i>Save Changes';
      }
    }
  });

  /* ── View Report — wired via event delegation ────────────────────────────── */
  document.addEventListener('click', function(e) {
    var btn = e.target.closest('.view-report-btn');
    if (!btn) return;
    openQcReportModal(btn.dataset.batchId, btn.dataset.batchNumber);
  });

  async function openQcReportModal(batchId, batchNumber) {
    var modal = new bootstrap.Modal(document.getElementById('qcReportModal'));
    document.getElementById('qcReportBatchNumber').textContent = batchNumber || '';
    document.getElementById('qcReportBody').innerHTML =
      '<div class="text-center text-muted py-3">'
      + '<div class="spinner-border spinner-border-sm me-2"></div>Loading…</div>';
    modal.show();

    try {
      var res  = await fetch('/batch/api/' + batchId + '/qc');
      var data = await res.json();
      if (!res.ok || data.error) throw new Error(data.error || 'Failed to load report');

      var report     = (data.rejectionReport || '').trim();
      var updatedStr = '';
      if (data.qualityUpdatedAt) {
        var d = data.qualityUpdatedAt._seconds
          ? new Date(data.qualityUpdatedAt._seconds * 1000)
          : new Date(data.qualityUpdatedAt);
        updatedStr = d.toLocaleString();
      }

      document.getElementById('qcReportBody').innerHTML = report
        ? '<div class="mb-2 text-muted small"><i class="bi bi-clock me-1"></i>Rejected on: '
          + escapeHtml(updatedStr || '—') + '</div>'
          + '<div class="p-3 rounded" style="background:#fef2f2;border:1px solid #fca5a5;'
          + 'white-space:pre-wrap;font-size:.95rem;line-height:1.6;">'
          + escapeHtml(report) + '</div>'
        : '<div class="alert alert-warning mb-0">'
          + '<i class="bi bi-info-circle me-1"></i>'
          + 'No rejection report was provided for this batch.</div>';
    } catch (err) {
      document.getElementById('qcReportBody').innerHTML =
        '<div class="alert alert-danger mb-0">'
        + '<i class="bi bi-exclamation-triangle me-1"></i>'
        + escapeHtml(err.message) + '</div>';
    }
  }
</script>

<script>
// ── Search across all batches (client-side filter over the rendered table) ────
(function(){
  var input = document.getElementById('batchSearch');
  if (!input) return; // table not present (no batches)
  var body = document.getElementById('batchTableBody');
  var noResults = document.getElementById('batchNoResults');
  var count = document.getElementById('batchSearchCount');
  var clearBtn = document.getElementById('batchSearchClear');
  // Only the real data rows (exclude the no-results row).
  var rows = Array.prototype.slice.call(body.querySelectorAll('tr')).filter(function(r){ return r.id !== 'batchNoResults'; });

  function apply(){
    var q = (input.value || '').trim().toLowerCase();
    var shown = 0;
    rows.forEach(function(row){
      // Match against the full visible text of the row (batch number, item,
      // type, template, QC status, date — everything in the row).
      var text = (row.textContent || '').toLowerCase();
      var match = q === '' || text.indexOf(q) !== -1;
      row.style.display = match ? '' : 'none';
      if (match) shown++;
    });
    noResults.style.display = shown === 0 ? '' : 'none';
    if (count) count.textContent = q === '' ? (rows.length + ' batch(es)') : (shown + ' of ' + rows.length + ' match');
  }

  input.addEventListener('input', apply);
  if (clearBtn) clearBtn.addEventListener('click', function(){ input.value=''; apply(); input.focus(); });
  apply(); // initialise the count
})();

// ── Live duplicate-batch-number check in the New Batch form ───────────────────
(function(){
  var field = document.getElementById('batchNumberInput');
  if (!field) return;
  var feedback = document.getElementById('batchNumberFeedback');
  var form = document.getElementById('batchForm');
  var timer = null;
  var lastResult = false; // true => duplicate

  function setState(state, msg){
    field.classList.remove('is-invalid', 'is-valid');
    feedback.classList.remove('text-danger', 'text-success');
    if (state === 'dup'){ field.classList.add('is-invalid'); feedback.classList.add('text-danger'); }
    else if (state === 'ok'){ field.classList.add('is-valid'); feedback.classList.add('text-success'); }
    feedback.textContent = msg || '';
  }

  async function check(){
    var v = (field.value || '').trim();
    if (!v){ setState('', ''); lastResult = false; return; }
    try {
      var res = await fetch('/batch/check-number?number=' + encodeURIComponent(v));
      var data = await res.json();
      lastResult = !!data.exists;
      if (data.exists) setState('dup', '⚠ This batch number already exists — choose a different one.');
      else setState('ok', '✓ Batch number is available.');
    } catch(e){ setState('', ''); lastResult = false; }
  }

  field.addEventListener('input', function(){
    clearTimeout(timer);
    timer = setTimeout(check, 350); // debounce while typing
  });

  // Block submission if the number is a known duplicate.
  if (form){
    form.addEventListener('submit', function(e){
      if (lastResult){
        e.preventDefault();
        setState('dup', '⚠ This batch number already exists — choose a different one.');
        field.focus();
      }
    });
  }
})();
</script>
