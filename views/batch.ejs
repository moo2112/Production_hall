<%- include('partials/header') %>

<div class="row">
  <div class="col-12">
    <div class="text-center mb-4">
      <h2 class="fw-bold"><i class="bi bi-collection" style="color:#7c3aed"></i> Batch Management</h2>
      <p class="text-muted">Record and trace production batches across all product tiers</p>
    </div>

    <% if (error) { %>
      <div class="alert alert-danger alert-dismissible fade show"><i class="bi bi-exclamation-triangle"></i> <%= error %><button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    <% } %>
    <% if (success) { %>
      <div class="alert alert-success alert-dismissible fade show"><i class="bi bi-check-circle"></i> <%= success %><button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    <% } %>

    <div class="mb-3 d-flex gap-2">
      <button class="btn btn-purple" style="background:#7c3aed;color:#fff" data-bs-toggle="modal" data-bs-target="#addBatchModal">
        <i class="bi bi-plus-circle"></i> New Batch Record
      </button>
      <a href="/form-builder" class="btn btn-outline-secondary">
        <i class="bi bi-ui-checks"></i> Manage Form Templates
      </a>
    </div>

    <!-- Batch Records Table -->
    <div class="card shadow-sm">
      <div class="card-body">
        <% if (batches.length === 0) { %>
          <div class="text-center text-muted py-5">
            <i class="bi bi-collection display-1" style="opacity:.2;color:#7c3aed"></i>
            <p class="mt-3">No batches recorded yet. Click "New Batch Record" to get started.</p>
          </div>
        <% } else { %>
          <div class="table-responsive">
            <table class="table table-hover align-middle">
              <thead class="table-light">
                <tr>
                  <th>#</th>
                  <th>Batch Number</th>
                  <th>Item Name</th>
                  <th>Item Type</th>
                  <th>Form Template</th>
                  <th>Date Recorded</th>
                  <th class="text-end">Actions</th>
                </tr>
              </thead>
              <tbody>
                <% batches.forEach((batch, index) => { %>
                  <tr>
                    <td><%= index + 1 %></td>
                    <td>
                      <button type="button" class="btn btn-sm text-white fw-semibold" style="background:#7c3aed" onclick="viewBatchDetails('<%= batch.id %>')" title="View all products related to this batch">
                        <i class="bi bi-tag-fill me-1"></i><%= batch.batchNumber %>
                      </button>
                    </td>
                    <td><strong><%= batch.itemName %></strong></td>
                    <td>
                      <% const typeColors = {Primary:'success',Secondary:'warning',Tertiary:'danger'}; %>
                      <span class="badge bg-<%= typeColors[batch.itemType] || 'secondary' %>"><%= batch.itemType || '-' %></span>
                    </td>
                    <td>
                      <% if (batch.formTemplateName) { %>
                        <%= batch.formTemplateName %>
                      <% } else { %>
                        <span class="text-muted">-</span>
                      <% } %>
                    </td>
                    <td class="text-muted small">
                      <%= batch.createdAt && batch.createdAt.toDate ? batch.createdAt.toDate().toLocaleString() : new Date(batch.createdAt).toLocaleString() %>
                    </td>
                    <td class="text-end">
                      <button class="btn btn-sm btn-outline-info" onclick="viewBatchDetails('<%= batch.id %>')" title="View Details">
                        <i class="bi bi-eye"></i>
                      </button>
                      <form action="/batch/<%= batch.id %>?_method=DELETE" method="POST" style="display:inline">
                        <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Delete this batch record?')">
                          <i class="bi bi-trash"></i>
                        </button>
                      </form>
                    </td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</div>

<!-- ── Add Batch Modal ──────────────────────────────────────────────────────── -->
<div class="modal fade" id="addBatchModal" tabindex="-1">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
      <div class="modal-header text-white" style="background:#7c3aed">
        <h5 class="modal-title"><i class="bi bi-plus-circle"></i> New Batch Record</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <form id="batchForm" action="/batch" method="POST">
        <div class="modal-body">

          <!-- Step 1: Choose form template (optional) -->
          <div class="mb-4">
            <label class="form-label fw-semibold">Form Template <span class="text-muted fw-normal">(optional)</span></label>
            <select class="form-select" id="templateSelector" onchange="loadTemplate(this.value)">
              <option value="">— No template / use default fields —</option>
              <% templates.forEach(t => { %>
                <option value="<%= t.id %>" data-name="<%= t.name %>" data-fields='<%- JSON.stringify(t.fields || []) %>'>
                  <%= t.name %>
                </option>
              <% }); %>
            </select>
            <input type="hidden" name="formTemplateId" id="formTemplateId">
            <input type="hidden" name="formTemplateName" id="formTemplateName">
          </div>

          <!-- Mandatory Fields (always shown) -->
          <div class="card border-primary mb-3">
            <div class="card-header bg-primary text-white py-2">
              <small><i class="bi bi-lock-fill me-1"></i> Required Fields — always present</small>
            </div>
            <div class="card-body">
              <div class="row g-3">
                <div class="col-md-6">
                  <label class="form-label fw-semibold">Batch Number <span class="text-danger">*</span></label>
                  <input type="text" class="form-control" name="batchNumber" placeholder="e.g. BATCH-2024-001" required>
                </div>
                <div class="col-md-6">
                  <label class="form-label fw-semibold">Item Name <span class="text-danger">*</span></label>
                  <select class="form-select" name="itemId" id="itemSelector" required onchange="syncItemName(this)">
                    <option value="">— Select a product —</option>
                    <% const grouped = {Primary:[],Secondary:[],Tertiary:[]}; %>
                    <% allProducts.forEach(p => { if(grouped[p.productType]) grouped[p.productType].push(p); }); %>
                    <% ['Primary','Secondary','Tertiary'].forEach(type => { %>
                      <% if(grouped[type].length > 0) { %>
                        <optgroup label="<%= type %> Products">
                          <% grouped[type].forEach(p => { %>
                            <option value="<%= p.id %>" data-type="<%= type %>" data-name="<%= p.name %>">
                              <%= p.name %>
                            </option>
                          <% }); %>
                        </optgroup>
                      <% } %>
                    <% }); %>
                  </select>
                  <input type="hidden" name="itemName" id="itemName">
                  <input type="hidden" name="itemType" id="itemType">
                </div>
              </div>
            </div>
          </div>

          <!-- Dynamic Fields Container -->
          <div id="dynamicFieldsContainer"></div>

        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn text-white" style="background:#7c3aed">
            <i class="bi bi-save"></i> Save Batch Record
          </button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- ── Batch Detail Modal ────────────────────────────────────────────────────── -->
<div class="modal fade" id="batchDetailModal" tabindex="-1">
  <div class="modal-dialog modal-xl">
    <div class="modal-content">
      <div class="modal-header text-white" style="background:#7c3aed">
        <h5 class="modal-title"><i class="bi bi-diagram-3"></i> Batch Details & Product Traceability</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body" id="batchDetailBody">
        <div class="text-center text-muted py-4">Loading batch details…</div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
      </div>
    </div>
  </div>
</div>

<script>
  function escapeHtml(value) {
    return String(value ?? '')
      .replaceAll('&', '&amp;')
      .replaceAll('<', '&lt;')
      .replaceAll('>', '&gt;')
      .replaceAll('"', '&quot;')
      .replaceAll("'", '&#039;');
  }

  function formatBatchDate(value) {
    if (!value) return '-';
    if (value._seconds) return new Date(value._seconds * 1000).toLocaleString();
    if (value.seconds) return new Date(value.seconds * 1000).toLocaleString();
    const date = new Date(value);
    return Number.isNaN(date.getTime()) ? '-' : date.toLocaleString();
  }

  function formatUnits(value) {
    const number = parseFloat(value || 0);
    return Number.isInteger(number) ? String(number) : number.toFixed(2).replace(/\.00$/, '');
  }

  function fieldInputName(fieldId) {
    const rawId = String(fieldId || '').trim();
    if (!rawId) return '';
    return rawId.startsWith('field_') ? rawId : `field_${rawId}`;
  }

  function humanizeFieldKey(key) {
    return String(key || '')
      .replace(/^field_/, '')
      .replace(/[_-]+/g, ' ')
      .replace(/\b\w/g, char => char.toUpperCase())
      .trim() || 'Custom Field';
  }

  function syncItemName(sel) {
    const opt = sel.options[sel.selectedIndex];
    document.getElementById('itemName').value = opt.dataset.name || '';
    document.getElementById('itemType').value = opt.dataset.type || '';
  }

  function loadTemplate(templateId) {
    const sel = document.getElementById('templateSelector');
    const opt = sel.options[sel.selectedIndex];
    document.getElementById('formTemplateId').value = templateId || '';
    document.getElementById('formTemplateName').value = opt ? (opt.dataset.name || '') : '';

    const container = document.getElementById('dynamicFieldsContainer');
    container.innerHTML = '';

    if (!templateId || !opt) return;
    let fields = [];
    try { fields = JSON.parse(opt.dataset.fields || '[]'); } catch(e) {}

    if (fields.length === 0) return;

    let html = '<div class="card border-secondary"><div class="card-header bg-secondary text-white py-2"><small><i class="bi bi-ui-checks me-1"></i> Template Fields</small></div><div class="card-body"><div class="row g-3">';
    fields.forEach(f => {
      const req = f.required ? 'required' : '';
      const reqMark = f.required ? '<span class="text-danger">*</span>' : '';
      const inputName = fieldInputName(f.id);
      html += `<div class="col-md-6"><label class="form-label fw-semibold">${escapeHtml(f.label)} ${reqMark}</label>`;
      if (f.type === 'text' || f.type === 'notes') {
        html += `<input type="text" class="form-control" name="${escapeHtml(inputName)}" placeholder="${escapeHtml(f.label)}" ${req}>`;
      } else if (f.type === 'number') {
        html += `<input type="number" class="form-control" name="${escapeHtml(inputName)}" step="0.01" ${req}>`;
      } else if (f.type === 'date') {
        html += `<input type="date" class="form-control" name="${escapeHtml(inputName)}" ${req}>`;
      } else if (f.type === 'dropdown' && f.options && f.options.length > 0) {
        html += `<select class="form-select" name="${escapeHtml(inputName)}" ${req}><option value="">— Select —</option>`;
        f.options.forEach(o => { html += `<option value="${escapeHtml(o)}">${escapeHtml(o)}</option>`; });
        html += `</select>`;
      } else {
        html += `<input type="text" class="form-control" name="${escapeHtml(inputName)}" ${req}>`;
      }
      html += `</div>`;
    });
    html += '</div></div></div>';
    container.innerHTML = html;
  }

  async function viewBatchDetails(batchId) {
    const modalElement = document.getElementById('batchDetailModal');
    const body = document.getElementById('batchDetailBody');
    body.innerHTML = '<div class="text-center text-muted py-4"><div class="spinner-border spinner-border-sm me-2"></div>Loading batch details…</div>';
    const modal = new bootstrap.Modal(modalElement);
    modal.show();

    try {
      const response = await fetch('/batch/api/' + batchId + '/details');
      const payload = await response.json();
      if (!response.ok || payload.error) throw new Error(payload.error || 'Failed to load batch details');
      renderBatchDetails(payload);
    } catch (error) {
      body.innerHTML = '<div class="alert alert-danger mb-0"><i class="bi bi-exclamation-triangle me-1"></i>' + escapeHtml(error.message) + '</div>';
    }
  }

  function renderBatchDetails(payload) {
    const batch = payload.batch || {};
    const directProducts = payload.directProducts || [];
    const consumedByProducts = payload.consumedByProducts || [];
    const customFields = payload.customFields || [];
    const fieldValues = batch.fieldValues || {};

    let html = `
      <div class="batch-detail-summary mb-4">
        <div class="row g-3">
          <div class="col-md-3"><div class="trace-card"><span class="trace-label">Batch Number</span><strong>${escapeHtml(batch.batchNumber || '-')}</strong></div></div>
          <div class="col-md-3"><div class="trace-card"><span class="trace-label">Linked Item</span><strong>${escapeHtml(batch.itemName || '-')}</strong></div></div>
          <div class="col-md-3"><div class="trace-card"><span class="trace-label">Item Type</span><strong>${escapeHtml(batch.itemType || '-')}</strong></div></div>
          <div class="col-md-3"><div class="trace-card"><span class="trace-label">Recorded</span><strong>${escapeHtml(formatBatchDate(batch.createdAt))}</strong></div></div>
        </div>
      </div>`;

    if (customFields.length > 0) {
      html += '<div class="card border-0 shadow-sm mb-4"><div class="card-header bg-light fw-semibold"><i class="bi bi-ui-checks me-1"></i>Custom Fields';
      if (payload.templateName) html += ` <span class="badge bg-secondary ms-2">${escapeHtml(payload.templateName)}</span>`;
      html += '</div><div class="card-body"><div class="row g-2">';
      customFields.forEach((field) => {
        html += `<div class="col-md-6"><div class="small text-muted">${escapeHtml(field.label || humanizeFieldKey(field.key))}</div><div class="fw-semibold">${escapeHtml(field.value || '-')}</div></div>`;
      });
      html += '</div></div></div>';
    } else if (Object.keys(fieldValues).length > 0) {
      html += '<div class="card border-0 shadow-sm mb-4"><div class="card-header bg-light fw-semibold"><i class="bi bi-ui-checks me-1"></i>Custom Fields</div><div class="card-body"><div class="row g-2">';
      Object.entries(fieldValues).forEach(([key, value]) => {
        html += `<div class="col-md-6"><div class="small text-muted">${escapeHtml(humanizeFieldKey(key))}</div><div class="fw-semibold">${escapeHtml(value || '-')}</div></div>`;
      });
      html += '</div></div></div>';
    }

    html += '<div class="row g-3">';
    html += '<div class="col-lg-6"><div class="card h-100 border-0 shadow-sm"><div class="card-header bg-light fw-semibold"><i class="bi bi-box-seam me-1"></i>Products with available stock in this batch</div><div class="card-body">';
    if (directProducts.length === 0) {
      html += '<div class="text-muted text-center py-4"><i class="bi bi-inbox display-6 opacity-25"></i><p class="mb-0 mt-2">No secondary or tertiary stock has been credited to this batch yet.</p></div>';
    } else {
      html += '<div class="table-responsive"><table class="table table-sm align-middle mb-0"><thead><tr><th>Tier</th><th>Product</th><th>Units</th><th>Relationship</th></tr></thead><tbody>';
      directProducts.forEach(item => {
        const badgeClass = item.tier === 'Tertiary' ? 'bg-danger' : 'bg-warning text-dark';
        html += `<tr><td><span class="badge ${badgeClass}">${escapeHtml(item.tier)}</span></td><td class="fw-semibold">${escapeHtml(item.productName)}</td><td>${formatUnits(item.units)}</td><td class="small text-muted">${escapeHtml(item.relationship)}</td></tr>`;
      });
      html += '</tbody></table></div>';
    }
    html += '</div></div></div>';

    html += '<div class="col-lg-6"><div class="card h-100 border-0 shadow-sm"><div class="card-header bg-light fw-semibold"><i class="bi bi-arrow-left-right me-1"></i>Products that consumed this batch</div><div class="card-body">';
    if (consumedByProducts.length === 0) {
      html += '<div class="text-muted text-center py-4"><i class="bi bi-diagram-3 display-6 opacity-25"></i><p class="mb-0 mt-2">No tertiary product has consumed this batch as a secondary input yet.</p></div>';
    } else {
      html += '<div class="table-responsive"><table class="table table-sm align-middle mb-0"><thead><tr><th>Tertiary Product</th><th>Tertiary Batch</th><th>Secondary Input</th><th>Units Used</th></tr></thead><tbody>';
      consumedByProducts.forEach(item => {
        html += `<tr><td class="fw-semibold">${escapeHtml(item.productName)}</td><td><span class="badge bg-danger">${escapeHtml(item.tertiaryBatchNumber || '-')}</span></td><td>${escapeHtml(item.sourceProductName || '-')}</td><td>${formatUnits(item.units)}</td></tr>`;
      });
      html += '</tbody></table></div>';
    }
    html += '</div></div></div>';
    html += '</div>';

    document.getElementById('batchDetailBody').innerHTML = html;
  }
</script>

<%- include('partials/footer') %>
