<%- include('partials/header') %>

<div class="row">
  <div class="col-12">
    <!-- Page Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h2 class="fw-bold">
        <i class="bi bi-box-seam text-info"></i> Consumables
      </h2>
      <button class="btn btn-info" data-bs-toggle="modal" data-bs-target="#addConsumableModal">
        <i class="bi bi-plus-circle"></i> New Item
      </button>
    </div>

    <!-- Alerts -->
    <% if (error) { %>
      <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle"></i> <%= error %>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      </div>
    <% } %>
    
    <% if (success) { %>
      <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle"></i> <%= success %>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      </div>
    <% } %>

    <!-- Consumables Table -->
    <div class="card shadow-sm">
      <div class="card-body">
        <% if (consumables.length === 0) { %>
          <div class="text-center text-muted py-5">
            <i class="bi bi-inbox display-1"></i>
            <p class="mt-3">No consumables found. Click "New Item" to add one.</p>
          </div>
        <% } else { %>
          <div class="table-responsive">
            <table class="table table-hover">
              <thead class="table-light">
                <tr>
                  <th>#</th>
                  <th>Name</th>
                  <th>Quantity</th>
                  <th>Created</th>
                  <th class="text-end">Actions</th>
                </tr>
              </thead>
              <tbody>
                <% consumables.forEach((consumable, index) => { %>
                  <tr>
                    <td><%= index + 1 %></td>
                    <td><strong><%= consumable.name %></strong></td>
                    <td>
                      <span class="badge bg-secondary"><%= consumable.quantity %></span>
                    </td>
                    <td>
                      <small class="text-muted">
                        <%= new Date(consumable.createdAt.seconds ? consumable.createdAt.seconds * 1000 : consumable.createdAt).toLocaleDateString() %>
                      </small>
                    </td>
                    <td class="text-end">
                      <button class="btn btn-sm btn-outline-danger"
                        onclick="openAdjustModal('<%= consumable.id %>', '<%= consumable.name %>', '<%= consumable.quantity %>', 'subtract')"
                        title="Subtract from quantity">
                        <i class="bi bi-dash-lg"></i>
                      </button>
                      <button class="btn btn-sm btn-outline-success ms-1"
                        onclick="openAdjustModal('<%= consumable.id %>', '<%= consumable.name %>', '<%= consumable.quantity %>', 'add')"
                        title="Add to quantity">
                        <i class="bi bi-plus-lg"></i>
                      </button>
                      <form action="/consumables/<%= consumable.id %>?_method=DELETE" method="POST" style="display: inline;">
                        <button type="submit" class="btn btn-sm btn-outline-danger ms-1" onclick="return confirm('Are you sure?')">
                          <i class="bi bi-trash"></i>
                        </button>
                      </form>
                    </td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</div>

<!-- Add Consumable Modal -->
<div class="modal fade" id="addConsumableModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header bg-info text-white">
        <h5 class="modal-title">
          <i class="bi bi-plus-circle"></i> Add New Consumable
        </h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <form action="/consumables" method="POST">
        <div class="modal-body">
          <div class="mb-3">
            <label for="name" class="form-label">Consumable Name *</label>
            <input type="text" class="form-control" id="name" name="name" required>
          </div>
          <div class="mb-3">
            <label for="quantity" class="form-label">Quantity *</label>
            <input type="number" class="form-control" id="quantity" name="quantity" step="0.01" min="0" required>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-info">
            <i class="bi bi-save"></i> Save Consumable
          </button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- Adjust Quantity Modal -->
<div class="modal fade" id="adjustQuantityModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header text-white" id="adjustModalHeader">
        <h5 class="modal-title" id="adjustModalTitle">Adjust Quantity</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <form id="adjustQuantityForm" action="" method="POST">
        <input type="hidden" name="_method" value="PATCH">
        <input type="hidden" name="action" id="adjustAction" value="">
        <div class="modal-body">
          <p class="text-muted mb-1">Consumable: <strong id="adjustItemName"></strong></p>
          <p class="text-muted mb-3">Current Quantity: <span class="badge bg-secondary" id="adjustCurrentQty"></span></p>
          <div class="mb-3">
            <label for="adjustAmount" class="form-label">Amount to <span id="adjustVerb"></span> *</label>
            <input type="number" class="form-control" id="adjustAmount" name="amount" step="0.01" min="0.01" required placeholder="Enter amount">
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn" id="adjustSubmitBtn">
            <i class="bi bi-check-lg"></i> OK
          </button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
function openAdjustModal(id, name, currentQty, action) {
  const isSubtract = action === 'subtract';
  document.getElementById('adjustModalHeader').className =
    'modal-header text-white ' + (isSubtract ? 'bg-danger' : 'bg-success');
  document.getElementById('adjustModalTitle').innerHTML =
    isSubtract
      ? '<i class="bi bi-dash-circle"></i> Subtract from Quantity'
      : '<i class="bi bi-plus-circle"></i> Add to Quantity';
  document.getElementById('adjustItemName').textContent = name;
  document.getElementById('adjustCurrentQty').textContent = currentQty;
  document.getElementById('adjustAction').value = action;
  document.getElementById('adjustVerb').textContent = isSubtract ? 'subtract' : 'add';
  document.getElementById('adjustSubmitBtn').className =
    'btn ' + (isSubtract ? 'btn-danger' : 'btn-success');
  document.getElementById('adjustAmount').value = '';
  document.getElementById('adjustQuantityForm').action = '/consumables/' + id + '/adjust';
  new bootstrap.Modal(document.getElementById('adjustQuantityModal')).show();
}
</script>

<%- include('partials/footer') %>