<%- include('partials/header') %>
<div class="row"><div class="col-12">
  <div class="text-center mb-4">
    <h2 class="fw-bold"><i class="bi bi-person-lines-fill text-primary"></i> Clients</h2>
    <p class="text-muted">Saved customers you can pick when making an invoice</p>
  </div>
  <% if (error) { %><div class="alert alert-danger"><i class="bi bi-exclamation-triangle"></i> <%= error %></div><% } %>
  <% if (success) { %><div class="alert alert-success"><i class="bi bi-check-circle"></i> <%= success %></div><% } %>

  <div class="card shadow-sm mb-4">
    <div class="card-header bg-primary text-white fw-semibold"><i class="bi bi-person-plus"></i> Add Client</div>
    <div class="card-body">
      <form action="/clients" method="POST" class="row g-2">
        <div class="col-md-3"><input class="form-control" name="name" placeholder="Name *" required></div>
        <div class="col-md-2"><input class="form-control" name="phone" placeholder="Phone"></div>
        <div class="col-md-3"><input type="email" class="form-control" name="email" placeholder="Email"></div>
        <div class="col-md-3"><input class="form-control" name="address" placeholder="Address"></div>
        <div class="col-md-1"><button class="btn btn-primary w-100"><i class="bi bi-save"></i></button></div>
      </form>
    </div>
  </div>

  <div class="card shadow-sm">
    <div class="card-body">
      <% if (clients.length === 0) { %><p class="text-muted text-center mb-0">No clients saved yet.</p><% } else { %>
      <div class="table-responsive">
        <table class="table table-hover align-middle">
          <thead class="table-light"><tr><th>Name</th><th>Phone</th><th>Email</th><th>Address</th><th class="text-end">Actions</th></tr></thead>
          <tbody>
            <% clients.forEach(c => { %>
              <tr>
                <td class="fw-semibold"><%= c.name %></td>
                <td><%= c.phone || '—' %></td>
                <td><%= c.email || '—' %></td>
                <td class="small text-muted"><%= c.address || '—' %></td>
                <td class="text-end">
                  <form action="/clients/<%= c.id %>?_method=DELETE" method="POST" class="d-inline" onsubmit="return confirm('Delete this client?')">
                    <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                  </form>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
      <% } %>
    </div>
  </div>
</div></div>
<%- include('partials/footer') %>
