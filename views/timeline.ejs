<%- include('partials/header') %>

<div class="row">
  <div class="col-12">
    <div class="text-center mb-4">
      <h2 class="fw-bold"><i class="bi bi-clock-history text-secondary"></i> Activity Timeline</h2>
      <p class="text-muted">Complete audit log of all system actions</p>
    </div>

    <% if (error) { %>
      <div class="alert alert-danger alert-dismissible fade show"><i class="bi bi-exclamation-triangle"></i> <%= error %><button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    <% } %>

    <!-- Controls -->
    <div class="d-flex flex-wrap gap-2 mb-3 align-items-center">
      <input type="text" class="form-control form-control-sm" id="searchInput" placeholder="&#128269; Search actions, items…" style="max-width:260px" oninput="filterTable()">
      <select class="form-select form-select-sm" id="typeFilter" style="max-width:180px" onchange="filterTable()">
        <option value="">All Types</option>
        <option>Consumable</option>
        <option>Primary</option>
        <option>Secondary</option>
        <option>Tertiary</option>
        <option>Batch</option>
        <option>FormTemplate</option>
      </select>
      <select class="form-select form-select-sm" id="statusFilter" style="max-width:160px" onchange="filterTable()">
        <option value="">All Statuses</option>
        <option>Finished</option>
        <option>Damaged</option>
      </select>
      <span class="text-muted small ms-1" id="rowCount"></span>
      <div class="ms-auto d-flex gap-2">
        <button class="btn btn-sm btn-outline-secondary" onclick="filterTable(true)"><i class="bi bi-arrow-clockwise"></i> Reset</button>
        <button class="btn btn-sm btn-danger" onclick="exportPDF()">
          <i class="bi bi-file-earmark-pdf"></i> Export PDF
        </button>
      </div>
    </div>

    <div class="card shadow-sm">
      <div class="card-body p-0">
        <% if (logs.length === 0) { %>
          <div class="text-center text-muted py-5">
            <i class="bi bi-clock-history display-1 opacity-25"></i>
            <p class="mt-3">No activity recorded yet. Actions taken in the system will appear here.</p>
          </div>
        <% } else { %>
          <div class="table-responsive">
            <table class="table table-hover table-sm align-middle mb-0" id="timelineTable">
              <thead class="table-dark">
                <tr>
                  <th class="ps-3">#</th>
                  <th>Timestamp</th>
                  <th>Action</th>
                  <th>Item Name</th>
                  <th>Item Type</th>
                  <th>Batch #</th>
                  <th>Qty</th>
                  <th>Status</th>
                  <th>Notes</th>
                </tr>
              </thead>
              <tbody id="timelineBody">
                <% logs.forEach((log, index) => { %>
                  <tr data-type="<%= log.itemType %>" data-status="<%= log.status || '' %>">
                    <td class="ps-3 text-muted"><%= index + 1 %></td>
                    <td class="text-muted small text-nowrap">
                      <%= log.timestamp.toLocaleString('en-GB', {day:'2-digit',month:'short',year:'numeric',hour:'2-digit',minute:'2-digit'}) %>
                    </td>
                    <td>
                      <% const actionIcons = {
                        'Created':'plus-circle-fill text-success',
                        'Deleted':'trash-fill text-danger',
                        'Updated':'pencil-fill text-primary',
                        'Produced':'play-circle-fill text-warning',
                        'Increased':'arrow-up-circle-fill text-info',
                      }; %>
                      <% const iconKey = Object.keys(actionIcons).find(k => log.action.includes(k)) || ''; %>
                      <% if(iconKey) { %><i class="bi bi-<%= actionIcons[iconKey] %> me-1"></i><% } %>
                      <small class="fw-semibold"><%= log.action %></small>
                    </td>
                    <td><%= log.itemName || '-' %></td>
                    <td>
                      <% const tc = {Primary:'success',Secondary:'warning',Tertiary:'danger',Consumable:'info',Batch:'', FormTemplate:'secondary'}; %>
                      <% if(log.itemType) { %>
                        <span class="badge bg-<%= tc[log.itemType] || 'secondary' %>" style="<%= log.itemType==='Batch' ? 'background:#7c3aed!important' : '' %>">
                          <%= log.itemType %>
                        </span>
                      <% } else { %>-<% } %>
                    </td>
                    <td>
                      <% if(log.batchNumber) { %>
                        <span class="badge" style="background:#7c3aed"><%= log.batchNumber %></span>
                      <% } else { %><span class="text-muted">-</span><% } %>
                    </td>
                    <td><%= log.quantity != null ? log.quantity : '-' %></td>
                    <td>
                      <% if(log.status === 'Finished') { %>
                        <span class="badge bg-success">✓ Finished</span>
                      <% } else if(log.status === 'Damaged') { %>
                        <span class="badge bg-danger">⚠ Damaged</span>
                      <% } else { %>-<% } %>
                    </td>
                    <td class="text-muted small"><%= log.notes || '-' %></td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>
    </div>

    <div class="text-start mt-3">
      <a href="/" class="btn btn-outline-secondary"><i class="bi bi-house me-1"></i> Home</a>
    </div>
  </div>
</div>

<!-- jsPDF for PDF export -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.5.28/jspdf.plugin.autotable.min.js"></script>

<script>
  // ── Filter ────────────────────────────────────────────────────────────────
  function filterTable(reset) {
    if (reset) {
      document.getElementById('searchInput').value = '';
      document.getElementById('typeFilter').value = '';
      document.getElementById('statusFilter').value = '';
    }
    const search = document.getElementById('searchInput').value.toLowerCase();
    const type   = document.getElementById('typeFilter').value;
    const status = document.getElementById('statusFilter').value;
    const rows   = document.querySelectorAll('#timelineBody tr');
    let visible  = 0;

    rows.forEach(row => {
      const text   = row.textContent.toLowerCase();
      const rType  = row.dataset.type   || '';
      const rStat  = row.dataset.status || '';
      const show   = (!search || text.includes(search))
                  && (!type   || rType  === type)
                  && (!status || rStat  === status);
      row.style.display = show ? '' : 'none';
      if (show) visible++;
    });

    document.getElementById('rowCount').textContent = `Showing ${visible} of ${rows.length} records`;
  }

  // ── PDF Export ────────────────────────────────────────────────────────────
  function exportPDF() {
    const { jsPDF } = window.jspdf;
    const doc = new jsPDF({ orientation: 'landscape', unit: 'mm', format: 'a4' });

    // Title
    doc.setFontSize(16);
    doc.setFont('helvetica', 'bold');
    doc.text('Production Hall — Activity Timeline', 14, 15);
    doc.setFontSize(9);
    doc.setFont('helvetica', 'normal');
    doc.setTextColor(100);
    doc.text('Generated: ' + new Date().toLocaleString(), 14, 22);
    doc.setTextColor(0);

    // Collect visible rows
    const rows = [];
    document.querySelectorAll('#timelineBody tr').forEach((row, i) => {
      if (row.style.display === 'none') return;
      const cells = row.querySelectorAll('td');
      rows.push([
        i + 1,
        cells[1]?.textContent.trim() || '',
        cells[2]?.textContent.trim() || '',
        cells[3]?.textContent.trim() || '',
        cells[4]?.textContent.trim() || '',
        cells[5]?.textContent.trim() || '',
        cells[6]?.textContent.trim() || '',
        cells[7]?.textContent.trim() || '',
        cells[8]?.textContent.trim() || '',
      ]);
    });

    doc.autoTable({
      startY: 27,
      head: [['#', 'Timestamp', 'Action', 'Item Name', 'Type', 'Batch #', 'Qty', 'Status', 'Notes']],
      body: rows,
      styles: { fontSize: 7.5, cellPadding: 2 },
      headStyles: { fillColor: [30, 58, 95], textColor: 255, fontStyle: 'bold' },
      alternateRowStyles: { fillColor: [245, 247, 250] },
      columnStyles: {
        0: { cellWidth: 8 },
        1: { cellWidth: 32 },
        2: { cellWidth: 50 },
        3: { cellWidth: 35 },
        4: { cellWidth: 22 },
        5: { cellWidth: 25 },
        6: { cellWidth: 12 },
        7: { cellWidth: 20 },
        8: { cellWidth: 'auto' },
      },
      didParseCell: function(data) {
        if (data.section === 'body') {
          const status = data.row.raw[7];
          if (status === '✓ Finished') {
            data.cell.styles.textColor = [22, 101, 52];
            data.cell.styles.fontStyle = 'bold';
          } else if (status === '⚠ Damaged') {
            data.cell.styles.textColor = [185, 28, 28];
            data.cell.styles.fontStyle = 'bold';
          }
        }
      },
    });

    // Footer
    const pageCount = doc.internal.getNumberOfPages();
    for (let i = 1; i <= pageCount; i++) {
      doc.setPage(i);
      doc.setFontSize(8);
      doc.setTextColor(150);
      doc.text(`Page ${i} of ${pageCount}`, doc.internal.pageSize.getWidth() - 30, doc.internal.pageSize.getHeight() - 8);
    }

    doc.save(`activity-timeline-${new Date().toISOString().slice(0,10)}.pdf`);
  }

  // Run filter count on load
  filterTable();
</script>

<%- include('partials/footer') %>
